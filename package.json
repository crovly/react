{
  "name": "@crovly/react",
  "version": "1.0.0",
  "description": "Official Crovly React SDK — captcha component and hook",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["crovly", "captcha", "react", "pow", "proof-of-work", "bot-protection"],
  "author": "Crovly <dev@crovly.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crovly/react"
  },
  "homepage": "https://crovly.com",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
